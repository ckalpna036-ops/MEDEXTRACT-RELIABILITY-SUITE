# ─────────────────────────────────────────────────
#  HiLabs Workshop — Environment Configuration
# ─────────────────────────────────────────────────

# LLM Provider: "gemini", "openai", "openrouter", or "mistral"
LLM_PROVIDER=gemini

# Google Gemini API Key (free tier available at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (alternative)
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter API Key (OpenAI-compatible)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional OpenRouter headers (recommended but optional)
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=

# Mistral API Key (OpenAI-compatible endpoint)
MISTRAL_API_KEY=your_mistral_api_key_here

# Model names (defaults shown)
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_MODEL=openai/gpt-4o-mini
MISTRAL_MODEL=mistral-small-latest

# Evaluation settings
FUZZY_MATCH_THRESHOLD=80   # Entity string similarity % to count as a match

# Paths
TEST_DATA_DIR=test_data
OUTPUT_DIR=output
